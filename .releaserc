{
  "branches": [
    "main"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/github",
    [
      "@semantic-release/exec",
      {
        "publishCmd": "echo \"TODO: Publish Docker image or MCP package for this release (version ${nextRelease.version})\""
      }
    ]
  ]
}


{
  "branches": [
    "main"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/github",
    [
      "@semantic-release/exec",
      {
        "publishCmd": "echo \"Release ${nextRelease.version} created; tag v${nextRelease.version} will trigger publish-mcp workflow to build Docker image and publish to MCP registry\""
      }
    ]
  ]
}

